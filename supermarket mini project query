--SECTION A-Basic Aggregate Functions

--This is to select all the data
SELECT *
FROM dbo.Supermarket

--This is to show the total number of transactions
SELECT COUNT(TransactionID) as Total_number_of_transactions
FROM dbo.Supermarket

--This is to find the total quantity of items sold
SELECT SUM(Quantity) AS Total_quantity_of_items_sold
FROM dbo.Supermarket

--This is to calculate the average unit price of the products
SELECT Round(AVG(UnitPrice), 2) AS Average_UnitPrice_Of_the_products
FROM dbo.Supermarket

--This is to find the highest UnitPrice
SELECT MAX(UnitPrice) AS Highest_UnitPrice
FROM dbo.Supermarket

--This is to find the lowest UnitPrice
SELECT MIN(UnitPrice) AS Lowest_UnitPrice
FROM dbo.Supermarket

--SECTION B-Aggregates With GROUP BY

--This is to find the total quantity sold for each product category
SELECT ProductCategory, SUM(Quantity) as Total_Quantity_by_category
FROM dbo.Supermarket 
GROUP BY ProductCategory

--This is to find the number of transactions in each city
SELECT  CITY,COUNT(TransactionID) as Total_number_of_transations_in_each_city
FROM dbo.Supermarket 
GROUP BY City

--This is to find the average unit price for each category
 SELECT ProductCategory,ROUND(AVG(UnitPrice),1 )AS Average_UnitPrice_of_each_ProductCategory
 FROM dbo.Supermarket
 GROUP BY ProductCategory

--This is calculate the total revenue of each product category
SELECT ProductCategory,ROUND(SUM(Quantity*UnitPrice),2) AS Total_Revenue
FROM dbo.Supermarket 
GROUP BY ProductCategory


--Section C- Advanced Aggregations

--Total revenue generated by each city
SELECT City,ROUND(SUM(Quantity*UnitPrice),1) as Total_Revenue
FROM dbo.Supermarket
GROUP BY City

--Product with the highest total revenue
SELECT ProductName,ROUND(SUM(Quantity*UnitPrice),1) as Total_Revenue
FROM dbo.Supermarket
GROUP BY ProductName
ORDER BY ROUND(SUM(Quantity*UnitPrice),1) DESC

--Total Quantity of the top 3 most sold products
SELECT TOP 3 ProductName, SUM(Quantity) AS Total_Quantity
FROM dbo.Supermarket
GROUP BY ProductName
ORDER BY SUM(Quantity) DESC

--Average quantity purchased per transaction
SELECT TransactionID,AVG(Quantity) AS Average_Quantity_Sold 
FROM dbo.Supermarket
GROUP BY TransactionID

--Total revenue generated by each payment method
SELECT PaymentMethod ,ROUND(SUM(Quantity*UnitPrice),1) AS Total_Revenue
FROM dbo.Supermarket
GROUP BY PaymentMethod


--Section D -Using HAVING Clause 

--Product category with total quantity that are greater than 15
SELECT ProductCategory, SUM(Quantity) AS Total_Quantity
FROM dbo.Supermarket
GROUP BY ProductCategory
HAVING SUM(Quantity) > 15

--Products whose average unitprice exceeds 5
SELECT ProductName,ROUND(AVG(UnitPrice),0) AS Average_UnitPrice
FROM dbo.Supermarket
GROUP BY ProductName
HAVING AVG(UnitPrice) > 5

--Payment methods used in more than 5 transactions
SELECT COUNT(TransactionID) AS Count_of_trans, PaymentMethod
FROM dbo.Supermarket
GROUP BY PaymentMethod
HAVING COUNT(TransactionID) > 5

--Payment Method with more than 5 transactions
SELECT COUNT(TransactionID) AS ProductCategory_with_more_than_trans,ProductCategory
FROM dbo.Supermarket
Group BY ProductCategory
HAVING COUNT(TransactionID) > 8 


